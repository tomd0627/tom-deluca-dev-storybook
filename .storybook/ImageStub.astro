---
// Stub Image component for Storybook - simple passthrough that renders img tags
// without using Astro's image service (which isn't configured in Storybook)
export interface Props {
  src: string | { src: string; width?: number; height?: number };
  alt: string;
  loading?: string;
  [key: string]: any;
}

const { src, alt, loading, ...rest } = Astro.props;

// Handle both string paths and imported image objects
let srcUrl = '';
if (typeof src === 'string') {
  srcUrl = src;
} else if (src && typeof src === 'object' && 'src' in src) {
  srcUrl = (src as any).src;
}
---

<img src={srcUrl} alt={alt} {loading} {...rest} />
